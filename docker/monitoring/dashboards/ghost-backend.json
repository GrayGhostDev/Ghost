{
  "annotations": {
    "list": []
  },
  "description": "Ghost Backend API — request rates, latency, error rates, active connections",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "uid": "ggdc-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "rate(ghost_http_requests_total[5m])",
          "legendFormat": "{{method}} {{endpoint}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "title": "Active Requests",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "uid": "ggdc-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "ghost_http_requests_active",
          "legendFormat": "active"
        }
      ]
    },
    {
      "title": "Error Rate (5xx)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "uid": "ggdc-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(ghost_http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "uid": "ggdc-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(ghost_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(ghost_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(ghost_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Request Rate by Status Code",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "uid": "ggdc-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by (status) (rate(ghost_http_requests_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "title": "Redis — Connected Clients",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "uid": "ggdc-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "redis_connected_clients{instance=~\".*ghost.*\"}",
          "legendFormat": "clients"
        }
      ]
    },
    {
      "title": "Redis — Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "uid": "ggdc-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{instance=~\".*ghost.*\"}",
          "legendFormat": "used"
        },
        {
          "expr": "redis_memory_max_bytes{instance=~\".*ghost.*\"}",
          "legendFormat": "max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "title": "PostgreSQL — Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "uid": "ggdc-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "pg_stat_activity_count{instance=~\".*ghost.*\"}",
          "legendFormat": "{{state}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["ghost-backend", "ggdc", "level-2"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Ghost Backend",
  "uid": "ghost-backend",
  "version": 1
}
