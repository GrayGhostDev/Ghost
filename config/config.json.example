{
  "environment": "development",
  "debug": true,
  "project_name": "Ghost Backend",
  "version": "1.0.0",

  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "ghost_db",
    "user": "postgres",
    "password": "",
    "driver": "postgresql",
    "pool_size": 10,
    "max_overflow": 20,
    "echo": false
  },

  "redis": {
    "host": "localhost",
    "port": 6379,
    "db": 0,
    "password": "",
    "decode_responses": true
  },

  "api": {
    "host": "127.0.0.1",
    "port": 8000,
    "debug": false,
    "reload": false,
    "workers": 1,
    "cors_origins": ["*"],
    "rate_limit": "100/minute",
    "api_key": "",
    "jwt_secret": "",
    "jwt_algorithm": "HS256",
    "jwt_expiry_hours": 24
  },

  "logging": {
    "level": "INFO",
    "format": "{time:YYYY-MM-DD HH:mm:ss} | {level} | {name}:{function}:{line} | {message}",
    "json_output": false,
    "file_path": null,
    "max_size": "10 MB",
    "retention": "30 days",
    "compression": "zip"
  },

  "auth": {
    "jwt_secret": "change-this-to-a-long-random-string",
    "jwt_algorithm": "HS256",
    "access_token_expire_minutes": 30,
    "refresh_token_expire_days": 7,
    "jwt_expiry_hours": 24,
    "password_min_length": 8
  },

  "external_apis": {
    "openai_api_key": "",
    "anthropic_api_key": "",
    "github_token": "",
    "sentry_dsn": ""
  },

  "custom": {}
}
