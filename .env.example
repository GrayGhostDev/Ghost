# Ghost Backend Framework - Environment Configuration
# Copy this file to .env and modify the values as needed
#
# For Docker: values are overridden by docker-compose environment section
# For local dev: source via `source .env` or direnv (.envrc)

# Basic settings
ENVIRONMENT=development
DEBUG=true
PROJECT_NAME=Ghost Backend
VERSION=1.0.0

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ghost_db
DB_USER=postgres
DB_PASSWORD=changeme
DB_DRIVER=postgresql
# DATABASE_URL overrides all individual DB_* vars if set:
# DATABASE_URL=postgresql://postgres:changeme@localhost:5432/ghost_db

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=changeme

# API configuration
API_HOST=127.0.0.1
API_PORT=8801
API_KEY=
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# External API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_ADMIN_API_KEY=
GITHUB_PAT=
BRAVE_API_KEY=
SENDGRID_API_KEY=
SENTRY_DSN=

# Logging
LOG_LEVEL=INFO

# Python path (for local development)
PYTHONPATH=./src
