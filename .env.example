# =============================================================================
# Ghost Backend Framework — Environment Configuration
# =============================================================================
# GGDC-System Level 2 service
# Ports: API 8801, DB 127.0.0.1:5433, Redis 127.0.0.1:6380
# Secrets source: 1Password vault "GGDC / ghost-backend"
#
# Copy this file to .env and modify the values as needed:
#   cp .env.example .env
#
# For Docker: values are overridden by docker-compose environment section
# For local dev: source via `source .env` or direnv (.envrc)
#
# NOTE: These secrets can also be set in Level 2 docker/.env (as GHOST_BE_* vars)
# for compose orchestration from the GGDC-System root. This file takes precedence
# when running docker compose directly from this directory.
# =============================================================================

# ── Basic Settings ─────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
PROJECT_NAME=Ghost Backend
VERSION=1.0.0

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
# Docker Compose: host=postgres (container name), port=5432 (internal)
# Local dev: host=localhost, port=5433 (host-mapped)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ghost_db
DB_USER=postgres
DB_PASSWORD=changeme
DB_DRIVER=postgresql
# DATABASE_URL overrides all individual DB_* vars if set:
# DATABASE_URL=postgresql://postgres:changeme@localhost:5432/ghost_db

# ── Redis ──────────────────────────────────────────────────────────────────
# Docker Compose: host=redis (container name), port=6379 (internal)
# Local dev: host=localhost, port=6380 (host-mapped)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=changeme

# ── API Configuration ─────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8801
API_KEY=
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── External API Keys ─────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_ADMIN_API_KEY=
GITHUB_PAT=
BRAVE_API_KEY=
SENDGRID_API_KEY=
SENTRY_DSN=

# ── GCP (Optional — for Secret Manager overlay) ───────────────────────────
# Set GCP_SECRET_PROJECT to enable GCP Secret Manager as a fallback for empty vars
# GCP_SECRET_PROJECT=sylvan-flight-476922-m7

# ── Observability ──────────────────────────────────────────────────────────
# OpenTelemetry (traces export to Level 2 Jaeger)
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SERVICE_NAME=ghost-backend

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Python Path (for local development) ────────────────────────────────────
PYTHONPATH=./src
